// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  password  String
  role      Role     @default(USER)
  // Relationship: One user can have many chats
  chats     Chat[]
}

model Chat {
  id        Int       @id @default(autoincrement())
  userId    Int
  title     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relationship: One chat belongs to one user
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Relationship: One chat can have many messages
  messages  Message[]
}

model Message {
  id                   Int         @id @default(autoincrement())
  chatId               Int
  content              String?
  is_belonging_to_user Boolean     @default(false)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  // Relationship: One message belongs to one chat
  chat                 Chat         @relation(fields: [chatId], references: [id], onDelete: Cascade)
  attachments          Attachment[]
}

model Attachment {
  id        Int      @id @default(autoincrement())
  messageId Int
  content   String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
}